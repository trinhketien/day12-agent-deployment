# Copy file này thành .env.local và điền giá trị thật
# ❌ KHÔNG commit .env.local lên Git (đã có trong .gitignore)

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# ── App ─────────────────────────────────────────────────────
APP_NAME=Production AI Agent
APP_VERSION=1.0.0

# ── LLM —————————────────————————————————————————————————————
# Để trống = dùng mock LLM (không cần API key)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# ── Security — BẮT BUỘC thay đổi trong production! ──────────
AGENT_API_KEY=dev-key-change-me-in-production
JWT_SECRET=dev-jwt-secret-change-in-production

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10

# ── Budget ───────────────────────────────────────────────────
MONTHLY_BUDGET_USD=10.0
DAILY_BUDGET_USD=5.0

# ── Storage ─────────────────────────────────────────────────
# Local: để trống (in-memory fallback)
# Docker: redis://redis:6379/0
# Railway: ${{Redis.REDIS_URL}}
REDIS_URL=

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
